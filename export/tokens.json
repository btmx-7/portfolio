{
  "$description": "Portfolio MBT — All token sets. Import file for Penpot: Tokens → Import → IMPORT SINGLE JSON FILE. First-level keys = set names.",
  "primitives": {
    "color": {
      "cream":  { "$value": "#F2EDE4", "$type": "color", "$description": "Calcaire clair — background light mode" },
      "ink":    { "$value": "#1C1E26", "$type": "color", "$description": "Encre nuit — texte principal light mode" },
      "sand":   { "$value": "#E8E2D8", "$type": "color", "$description": "Sable — surface / meta backgrounds" },
      "ivory":  { "$value": "#FDFAF6", "$type": "color", "$description": "Ivoire — surface élevée" },
      "stone":  { "$value": "#D8D1C4", "$type": "color", "$description": "Pierre — bordures light mode" },
      "pebble": { "$value": "#4A4840", "$type": "color", "$description": "Galet — texte secondaire light mode" },
      "slate":  { "$value": "#8A8474", "$type": "color", "$description": "Ardoise — texte muted" },
      "indigo": { "$value": "#0C0E1A", "$type": "color", "$description": "Nuit indigo — background dark mode & work L1" },
      "warm":   { "$value": "#DDD3C4", "$type": "color", "$description": "Blanc chaud — texte sur fond sombre" },
      "green":  { "$value": "#3A7A5A", "$type": "color", "$description": "Chêne vert — accent light mode" },
      "sunset": { "$value": "#C46828", "$type": "color", "$description": "Soleil couchant — accent dark mode & work accent" },
      "white":  { "$value": "#FFFFFF", "$type": "color", "$description": "Blanc pur" },
      "black":  { "$value": "#000000", "$type": "color", "$description": "Noir pur" }
    },
    "space": {
      "1":  { "$value": 4,   "$type": "spacing", "$description": "--space-1" },
      "2":  { "$value": 8,   "$type": "spacing", "$description": "--space-2" },
      "3":  { "$value": 12,  "$type": "spacing", "$description": "--space-3" },
      "4":  { "$value": 16,  "$type": "spacing", "$description": "--space-4" },
      "5":  { "$value": 20,  "$type": "spacing", "$description": "--space-5" },
      "6":  { "$value": 24,  "$type": "spacing", "$description": "--space-6 / --container-padding" },
      "8":  { "$value": 32,  "$type": "spacing", "$description": "--space-8" },
      "10": { "$value": 40,  "$type": "spacing", "$description": "--space-10" },
      "12": { "$value": 48,  "$type": "spacing", "$description": "--space-12" },
      "16": { "$value": 64,  "$type": "spacing", "$description": "--space-16" },
      "20": { "$value": 80,  "$type": "spacing", "$description": "--space-20" },
      "24": { "$value": 96,  "$type": "spacing", "$description": "--space-24" },
      "32": { "$value": 128, "$type": "spacing", "$description": "--space-32" }
    },
    "radius": {
      "sm":   { "$value": 4,    "$type": "borderRadius", "$description": "--radius-sm" },
      "md":   { "$value": 8,    "$type": "borderRadius", "$description": "--radius-md" },
      "lg":   { "$value": 12,   "$type": "borderRadius", "$description": "--radius-lg" },
      "xl":   { "$value": 16,   "$type": "borderRadius", "$description": "--radius-xl (project cards)" },
      "full": { "$value": 9999, "$type": "borderRadius", "$description": "--radius-full (pills, badges)" }
    },
    "font": {
      "display": { "$value": "Plus Jakarta Sans", "$type": "fontFamily", "$description": "--font-display" },
      "body":    { "$value": "Work Sans",         "$type": "fontFamily", "$description": "--font-body" }
    },
    "fontSize": {
      "xs":   { "$value": 12, "$type": "fontSize", "$description": "--font-size-xs" },
      "sm":   { "$value": 14, "$type": "fontSize", "$description": "--font-size-sm" },
      "base": { "$value": 16, "$type": "fontSize", "$description": "--font-size-base" },
      "lg":   { "$value": 18, "$type": "fontSize", "$description": "--font-size-lg" },
      "xl":   { "$value": 20, "$type": "fontSize", "$description": "--font-size-xl" },
      "2xl":  { "$value": 24, "$type": "fontSize", "$description": "--font-size-2xl (project titles)" },
      "3xl":  { "$value": 30, "$type": "fontSize", "$description": "--font-size-3xl (outcome numbers)" },
      "4xl":  { "$value": 36, "$type": "fontSize", "$description": "--font-size-4xl" },
      "5xl":  { "$value": 48, "$type": "fontSize", "$description": "--font-size-5xl (hero)" },
      "6xl":  { "$value": 60, "$type": "fontSize", "$description": "--font-size-6xl (hero large)" }
    },
    "fontWeight": {
      "light":    { "$value": 300, "$type": "fontWeight", "$description": "--font-weight-light" },
      "normal":   { "$value": 400, "$type": "fontWeight", "$description": "--font-weight-normal" },
      "medium":   { "$value": 500, "$type": "fontWeight", "$description": "--font-weight-medium" },
      "semibold": { "$value": 600, "$type": "fontWeight", "$description": "--font-weight-semibold" },
      "bold":     { "$value": 700, "$type": "fontWeight", "$description": "--font-weight-bold" }
    }
  },
  "light": {
    "$description": "Mode Light (Midi en Occitanie) — correspond au :root de styles.css",
    "color": {
      "background":       { "$value": "{primitives.color.cream}",  "$type": "color", "$description": "--color-background (#F2EDE4)" },
      "surface":          { "$value": "{primitives.color.sand}",   "$type": "color", "$description": "--color-surface (#E8E2D8)" },
      "surface-elevated": { "$value": "{primitives.color.ivory}",  "$type": "color", "$description": "--color-surface-elevated (#FDFAF6)" },
      "surface-dark":     { "$value": "{primitives.color.ink}",    "$type": "color", "$description": "--color-surface-dark (#1C1E26)" },
      "text":             { "$value": "{primitives.color.ink}",    "$type": "color", "$description": "--color-text (#1C1E26)" },
      "text-secondary":   { "$value": "{primitives.color.pebble}", "$type": "color", "$description": "--color-text-secondary (#4A4840)" },
      "text-muted":       { "$value": "{primitives.color.slate}",  "$type": "color", "$description": "--color-text-muted (#8A8474)" },
      "text-on-dark":     { "$value": "{primitives.color.cream}",  "$type": "color", "$description": "--color-text-on-dark (#F2EDE4)" },
      "border":           { "$value": "{primitives.color.stone}",  "$type": "color", "$description": "--color-border (#D8D1C4)" },
      "accent":           { "$value": "{primitives.color.green}",  "$type": "color", "$description": "--color-accent (#3A7A5A, chêne vert)" },
      "accent-secondary": { "$value": "#7A9830",                   "$type": "color", "$description": "--color-accent-secondary" },
      "accent-tertiary":  { "$value": "#2A6BA0",                   "$type": "color", "$description": "--color-accent-tertiary" },
      "error":            { "$value": "#C0392B",                   "$type": "color", "$description": "--color-error" },
      "success":          { "$value": "#2E7D32",                   "$type": "color", "$description": "--color-success" }
    }
  },
  "dark": {
    "$description": "Mode Dark (Crépuscule) — correspond au html[data-theme='dark'] de styles.css",
    "color": {
      "background":       { "$value": "{primitives.color.indigo}", "$type": "color", "$description": "--color-background dark (#0C0E1A)" },
      "surface":          { "$value": "#131627",                   "$type": "color", "$description": "--color-surface dark (#131627)" },
      "surface-elevated": { "$value": "#191D32",                   "$type": "color", "$description": "--color-surface-elevated dark (#191D32)" },
      "surface-dark":     { "$value": "#08090F",                   "$type": "color", "$description": "--color-surface-dark dark (#08090F)" },
      "text":             { "$value": "{primitives.color.warm}",   "$type": "color", "$description": "--color-text dark (#DDD3C4)" },
      "text-secondary":   { "$value": "#9A8E80",                   "$type": "color", "$description": "--color-text-secondary dark (#9A8E80)" },
      "text-muted":       { "$value": "#5A5468",                   "$type": "color", "$description": "--color-text-muted dark (#5A5468)" },
      "text-on-dark":     { "$value": "{primitives.color.warm}",   "$type": "color", "$description": "--color-text-on-dark dark (#DDD3C4)" },
      "border":           { "$value": "#252840",                   "$type": "color", "$description": "--color-border dark (#252840)" },
      "accent":           { "$value": "{primitives.color.sunset}", "$type": "color", "$description": "--color-accent dark (#C46828, soleil couchant)" },
      "accent-secondary": { "$value": "#7B6090",                   "$type": "color", "$description": "--color-accent-secondary dark (#7B6090)" },
      "accent-tertiary":  { "$value": "#253060",                   "$type": "color", "$description": "--color-accent-tertiary dark (#253060)" },
      "error":            { "$value": "#C0392B",                   "$type": "color", "$description": "--color-error (inchangé en dark)" },
      "success":          { "$value": "#2E7D32",                   "$type": "color", "$description": "--color-success (inchangé en dark)" }
    }
  },
  "work": {
    "$description": "Sous-système Work section — Imbrication inversée (L1 nuit indigo → L2 calcaire clair → L3 glass). Indépendant du thème light/dark global.",
    "l1": {
      "$description": "L1 — Section fond nuit indigo",
      "bg":     { "$value": "{primitives.color.indigo}", "$type": "color", "$description": "--work-l1-bg (#0C0E1A)" },
      "text":   { "$value": "{primitives.color.warm}",   "$type": "color", "$description": "--work-l1-text (#DDD3C4) — opacité 100%" },
      "text-2": { "$value": "{primitives.color.warm}",   "$type": "color", "$description": "--work-l1-text-2 (#DDD3C4) — appliquer opacité 60% sur le shape Penpot" },
      "text-3": { "$value": "{primitives.color.warm}",   "$type": "color", "$description": "--work-l1-text-3 (#DDD3C4) — appliquer opacité 35% sur le shape Penpot" },
      "border": { "$value": "{primitives.color.white}",  "$type": "color", "$description": "--work-l1-border (#FFFFFF) — appliquer opacité 8% sur le shape Penpot" }
    },
    "l2": {
      "$description": "L2 — Carte projet calcaire clair",
      "bg":         { "$value": "{primitives.color.cream}",  "$type": "color", "$description": "--work-l2-bg (#F2EDE4)" },
      "border":     { "$value": "{primitives.color.stone}",  "$type": "color", "$description": "--work-l2-border (#D8D1C4)" },
      "text":       { "$value": "{primitives.color.ink}",    "$type": "color", "$description": "--work-l2-text (#1C1E26)" },
      "text-2":     { "$value": "{primitives.color.pebble}", "$type": "color", "$description": "--work-l2-text-2 (#4A4840)" },
      "text-3":     { "$value": "{primitives.color.slate}",  "$type": "color", "$description": "--work-l2-text-3 (#8A8474)" },
      "meta-bg":    { "$value": "{primitives.color.sand}",   "$type": "color", "$description": "--work-l2-meta-bg (#E8E2D8)" },
      "type-color": { "$value": "{primitives.color.green}",  "$type": "color", "$description": "--work-l2-type-color (#3A7A5A)" },
      "type-border":{ "$value": "{primitives.color.green}",  "$type": "color", "$description": "--work-l2-type-border (#3A7A5A) — appliquer opacité 30% sur le shape" },
      "type-bg":    { "$value": "{primitives.color.green}",  "$type": "color", "$description": "--work-l2-type-bg (#3A7A5A) — appliquer opacité 6% sur le shape" }
    },
    "l3": {
      "$description": "L3 — Bloc visuels glass clair. Penpot ne supporte pas backdrop-filter — représenter avec opacité.",
      "bg":          { "$value": "{primitives.color.ivory}", "$type": "color", "$description": "--work-l3-bg (#FDFAF6) — appliquer opacité 55% sur le shape" },
      "border":      { "$value": "{primitives.color.white}", "$type": "color", "$description": "--work-l3-border (#FFFFFF) — appliquer opacité 55% sur le shape" },
      "tabs-bg":     { "$value": "{primitives.color.white}", "$type": "color", "$description": "--work-l3-tabs-bg (#FFFFFF) — opacité 28%" },
      "tabs-border": { "$value": "{primitives.color.ink}",   "$type": "color", "$description": "--work-l3-tabs-border (#1C1E26) — opacité 8%" },
      "ph-bg":       { "$value": "{primitives.color.white}", "$type": "color", "$description": "--work-l3-ph-bg (#FFFFFF) — opacité 50%" },
      "ph-border":   { "$value": "{primitives.color.ink}",   "$type": "color", "$description": "--work-l3-ph-border (#1C1E26) — opacité 12%" }
    },
    "accent": { "$value": "{primitives.color.sunset}", "$type": "color", "$description": "--work-accent (#C46828, soleil couchant)" }
  }
}
