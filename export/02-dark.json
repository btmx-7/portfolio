{
  "$description": "Tokens sémantiques — Mode Dark (Crépuscule). Correspond au bloc html[data-theme='dark'] de styles.css. Mêmes noms de tokens que 01-light.json, valeurs inversées.",
  "color": {
    "background":       { "$value": "{primitive.color.indigo}", "$type": "color", "$description": "--color-background dark (#0C0E1A)" },
    "surface":          { "$value": "#131627",                  "$type": "color", "$description": "--color-surface dark (#131627)" },
    "surface-elevated": { "$value": "#191D32",                  "$type": "color", "$description": "--color-surface-elevated dark (#191D32)" },
    "surface-dark":     { "$value": "#08090F",                  "$type": "color", "$description": "--color-surface-dark dark (#08090F)" },
    "text":             { "$value": "{primitive.color.warm}",   "$type": "color", "$description": "--color-text dark (#DDD3C4)" },
    "text-secondary":   { "$value": "#9A8E80",                  "$type": "color", "$description": "--color-text-secondary dark (#9A8E80)" },
    "text-muted":       { "$value": "#5A5468",                  "$type": "color", "$description": "--color-text-muted dark (#5A5468)" },
    "text-on-dark":     { "$value": "{primitive.color.warm}",   "$type": "color", "$description": "--color-text-on-dark dark (#DDD3C4)" },
    "border":           { "$value": "#252840",                  "$type": "color", "$description": "--color-border dark (#252840)" },
    "accent":           { "$value": "{primitive.color.sunset}", "$type": "color", "$description": "--color-accent dark (#C46828, soleil couchant)" },
    "accent-secondary": { "$value": "#7B6090",                  "$type": "color", "$description": "--color-accent-secondary dark (#7B6090)" },
    "accent-tertiary":  { "$value": "#253060",                  "$type": "color", "$description": "--color-accent-tertiary dark (#253060)" },
    "error":            { "$value": "#C0392B",                  "$type": "color", "$description": "--color-error (inchangé en dark)" },
    "success":          { "$value": "#2E7D32",                  "$type": "color", "$description": "--color-success (inchangé en dark)" }
  }
}
