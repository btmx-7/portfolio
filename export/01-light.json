{
  "$description": "Tokens sémantiques — Mode Light (Midi en Occitanie). Correspond au bloc :root de styles.css. Les aliases {primitive.color.*} pointent vers 00-primitives.json.",
  "color": {
    "background":       { "$value": "{primitive.color.cream}",  "$type": "color", "$description": "--color-background (#F2EDE4)" },
    "surface":          { "$value": "{primitive.color.sand}",   "$type": "color", "$description": "--color-surface (#E8E2D8)" },
    "surface-elevated": { "$value": "{primitive.color.ivory}",  "$type": "color", "$description": "--color-surface-elevated (#FDFAF6)" },
    "surface-dark":     { "$value": "{primitive.color.ink}",    "$type": "color", "$description": "--color-surface-dark (#1C1E26)" },
    "text":             { "$value": "{primitive.color.ink}",    "$type": "color", "$description": "--color-text (#1C1E26)" },
    "text-secondary":   { "$value": "{primitive.color.pebble}", "$type": "color", "$description": "--color-text-secondary (#4A4840)" },
    "text-muted":       { "$value": "{primitive.color.slate}",  "$type": "color", "$description": "--color-text-muted (#8A8474)" },
    "text-on-dark":     { "$value": "{primitive.color.cream}",  "$type": "color", "$description": "--color-text-on-dark (#F2EDE4)" },
    "border":           { "$value": "{primitive.color.stone}",  "$type": "color", "$description": "--color-border (#D8D1C4)" },
    "accent":           { "$value": "{primitive.color.green}",  "$type": "color", "$description": "--color-accent (#3A7A5A, chêne vert)" },
    "accent-secondary": { "$value": "#7A9830",                  "$type": "color", "$description": "--color-accent-secondary" },
    "accent-tertiary":  { "$value": "#2A6BA0",                  "$type": "color", "$description": "--color-accent-tertiary" },
    "error":            { "$value": "#C0392B",                  "$type": "color", "$description": "--color-error" },
    "success":          { "$value": "#2E7D32",                  "$type": "color", "$description": "--color-success" }
  }
}
