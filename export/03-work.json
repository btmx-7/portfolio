{
  "$description": "Sous-système Work section — Imbrication inversée (L1 nuit indigo → L2 calcaire clair → L3 glass). Correspond aux tokens --work-* de styles.css. Indépendant du thème light/dark global.",
  "work": {
    "l1": {
      "$description": "L1 — Section fond nuit indigo (background sombre qui enveloppe les cartes)",
      "bg":     { "$value": "{primitive.color.indigo}", "$type": "color", "$description": "--work-l1-bg (#0C0E1A)" },
      "text":   { "$value": "{primitive.color.warm}",   "$type": "color", "$description": "--work-l1-text (#DDD3C4) — opacité 100%" },
      "text-2": { "$value": "{primitive.color.warm}",   "$type": "color", "$description": "--work-l1-text-2 (#DDD3C4) — appliquer opacité 60% sur le shape Penpot" },
      "text-3": { "$value": "{primitive.color.warm}",   "$type": "color", "$description": "--work-l1-text-3 (#DDD3C4) — appliquer opacité 35% sur le shape Penpot" },
      "border": { "$value": "{primitive.color.white}",  "$type": "color", "$description": "--work-l1-border (#FFFFFF) — appliquer opacité 8% sur le shape Penpot" }
    },
    "l2": {
      "$description": "L2 — Carte projet calcaire clair (emerge du fond sombre)",
      "bg":         { "$value": "{primitive.color.cream}",  "$type": "color", "$description": "--work-l2-bg (#F2EDE4)" },
      "border":     { "$value": "{primitive.color.stone}",  "$type": "color", "$description": "--work-l2-border (#D8D1C4)" },
      "text":       { "$value": "{primitive.color.ink}",    "$type": "color", "$description": "--work-l2-text (#1C1E26)" },
      "text-2":     { "$value": "{primitive.color.pebble}", "$type": "color", "$description": "--work-l2-text-2 (#4A4840)" },
      "text-3":     { "$value": "{primitive.color.slate}",  "$type": "color", "$description": "--work-l2-text-3 (#8A8474)" },
      "meta-bg":    { "$value": "{primitive.color.sand}",   "$type": "color", "$description": "--work-l2-meta-bg (#E8E2D8)" },
      "type-color": { "$value": "{primitive.color.green}",  "$type": "color", "$description": "--work-l2-type-color (#3A7A5A)" },
      "type-border":{ "$value": "{primitive.color.green}",  "$type": "color", "$description": "--work-l2-type-border (#3A7A5A) — appliquer opacité 30% sur le shape" },
      "type-bg":    { "$value": "{primitive.color.green}",  "$type": "color", "$description": "--work-l2-type-bg (#3A7A5A) — appliquer opacité 6% sur le shape" }
    },
    "l3": {
      "$description": "L3 — Bloc visuels glass clair (backdrop-filter sur les cartes L2). Penpot ne supporte pas backdrop-filter — représenter avec opacité.",
      "bg":     { "$value": "{primitive.color.ivory}", "$type": "color", "$description": "--work-l3-bg (#FDFAF6) — appliquer opacité 55% sur le shape" },
      "border": { "$value": "{primitive.color.white}", "$type": "color", "$description": "--work-l3-border (#FFFFFF) — appliquer opacité 55% sur le shape" },
      "tabs-bg":     { "$value": "{primitive.color.white}", "$type": "color", "$description": "--work-l3-tabs-bg (#FFFFFF) — opacité 28%" },
      "tabs-border": { "$value": "{primitive.color.ink}",   "$type": "color", "$description": "--work-l3-tabs-border (#1C1E26) — opacité 8%" },
      "ph-bg":       { "$value": "{primitive.color.white}", "$type": "color", "$description": "--work-l3-ph-bg (#FFFFFF) — opacité 50%" },
      "ph-border":   { "$value": "{primitive.color.ink}",   "$type": "color", "$description": "--work-l3-ph-border (#1C1E26) — opacité 12%" }
    },
    "accent": { "$value": "{primitive.color.sunset}", "$type": "color", "$description": "--work-accent (#C46828, soleil couchant) — CHALLENGE/OUTCOMES labels, arrows" }
  }
}
